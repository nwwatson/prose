<% content_for(:title, "#{t('admin.memberships.index.title')} — #{site_name}") %>

<div class="space-y-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('admin.memberships.index.title') %></h1>
    <div class="flex gap-2">
      <%= link_to t('shared.all'), admin_memberships_path, class: "rounded-md px-3 py-1.5 text-sm font-medium #{params[:status].blank? ? 'bg-gray-900 text-white' : 'bg-white text-gray-700 ring-1 ring-gray-300 hover:bg-gray-50'}" %>
      <%= link_to t('shared.active'), admin_memberships_path(status: "active"), class: "rounded-md px-3 py-1.5 text-sm font-medium #{params[:status] == 'active' ? 'bg-gray-900 text-white' : 'bg-white text-gray-700 ring-1 ring-gray-300 hover:bg-gray-50'}" %>
      <%= link_to t('admin.memberships.index.canceled'), admin_memberships_path(status: "canceled"), class: "rounded-md px-3 py-1.5 text-sm font-medium #{params[:status] == 'canceled' ? 'bg-gray-900 text-white' : 'bg-white text-gray-700 ring-1 ring-gray-300 hover:bg-gray-50'}" %>
    </div>
  </div>

  <% if @memberships.any? %>
    <div class="overflow-hidden bg-white shadow ring-1 ring-gray-200 sm:rounded-lg">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.memberships.index.subscriber') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.memberships.index.tier') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.memberships.index.status') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.memberships.index.since') %></th>
            <th class="relative px-6 py-3"><span class="sr-only"><%= t('shared.actions') %></span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @memberships.each do |membership| %>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= membership.subscriber.email %></td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= membership.membership_tier.name %></td>
              <td class="px-6 py-4 text-sm">
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                  <%= case membership.status
                      when 'active' then 'bg-green-100 text-green-800'
                      when 'past_due' then 'bg-yellow-100 text-yellow-800'
                      when 'canceled' then 'bg-red-100 text-red-800'
                      else 'bg-gray-100 text-gray-800'
                      end %>">
                  <%= membership.status.titleize %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= membership.created_at.strftime("%b %-d, %Y") %></td>
              <td class="whitespace-nowrap px-6 py-4 text-right text-sm font-medium">
                <%= link_to t('admin.memberships.index.view'), admin_membership_path(membership), class: "text-gray-600 hover:text-gray-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-lg border-2 border-dashed border-gray-300 p-12 text-center">
      <h3 class="text-sm font-semibold text-gray-900"><%= t('admin.memberships.index.no_members') %></h3>
      <p class="mt-1 text-sm text-gray-500"><%= t('admin.memberships.index.no_members_description') %></p>
    </div>
  <% end %>
</div>
