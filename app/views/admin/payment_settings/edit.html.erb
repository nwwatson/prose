<% content_for(:title, "#{t('admin.payment_settings.edit.title')} — #{site_name}") %>

<div class="max-w-4xl">
  <h1 class="text-2xl font-bold text-gray-900"><%= t('admin.payment_settings.edit.title') %></h1>
  <p class="mt-1 text-sm text-gray-600"><%= t('admin.payment_settings.edit.subtitle') %></p>

  <%= form_with model: @site_setting, url: admin_payment_settings_path, class: "mt-8 space-y-6" do |f| %>
    <% if @site_setting.errors.any? %>
      <div class="rounded-md bg-red-50 p-4">
        <ul class="list-disc pl-5 text-sm text-red-700">
          <% @site_setting.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <fieldset class="border-t border-gray-200 pt-6">
      <legend class="text-lg font-semibold text-gray-900"><%= t('admin.payment_settings.edit.stripe_keys') %></legend>
      <p class="mt-1 text-sm text-gray-600"><%= t('admin.payment_settings.edit.stripe_description') %></p>

      <div class="mt-4 max-w-lg space-y-4">
        <div>
          <%= f.label :stripe_publishable_key, t('admin.payment_settings.edit.publishable_key'), class: "block text-sm font-medium text-gray-900" %>
          <div class="mt-2">
            <%= f.password_field :stripe_publishable_key,
                  value: @site_setting.stripe_publishable_key.present? ? "••••••••" : "",
                  placeholder: "pk_live_...",
                  autocomplete: "off",
                  class: "block w-full rounded-md bg-white px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-600 sm:text-sm" %>
          </div>
        </div>

        <div>
          <%= f.label :stripe_secret_key, t('admin.payment_settings.edit.secret_key'), class: "block text-sm font-medium text-gray-900" %>
          <div class="mt-2">
            <%= f.password_field :stripe_secret_key,
                  value: @site_setting.stripe_secret_key.present? ? "••••••••" : "",
                  placeholder: "sk_live_...",
                  autocomplete: "off",
                  class: "block w-full rounded-md bg-white px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-600 sm:text-sm" %>
          </div>
        </div>

        <div>
          <%= f.label :stripe_webhook_secret, t('admin.payment_settings.edit.webhook_secret'), class: "block text-sm font-medium text-gray-900" %>
          <div class="mt-2">
            <%= f.password_field :stripe_webhook_secret,
                  value: @site_setting.stripe_webhook_secret.present? ? "••••••••" : "",
                  placeholder: "whsec_...",
                  autocomplete: "off",
                  class: "block w-full rounded-md bg-white px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-gray-600 sm:text-sm" %>
          </div>
          <p class="mt-1 text-xs text-gray-500"><%= t('admin.payment_settings.edit.webhook_help') %></p>
          <p class="mt-1 text-xs text-gray-500"><%= t('admin.payment_settings.edit.webhook_url') %> <code class="rounded bg-gray-100 px-1 py-0.5"><%= webhooks_stripe_url %></code></p>
        </div>
      </div>
    </fieldset>

    <fieldset class="border-t border-gray-200 pt-6">
      <legend class="text-lg font-semibold text-gray-900"><%= t('admin.payment_settings.edit.currency') %></legend>

      <div class="mt-4 max-w-lg">
        <div>
          <%= f.label :payments_currency, t('admin.payment_settings.edit.currency_label'), class: "block text-sm font-medium text-gray-900" %>
          <%= render "shared/custom_select", form: f, field: :payments_currency,
                options: SiteSetting::PaymentConfiguration::SUPPORTED_CURRENCIES.map { |k, v| [v, k] } %>
        </div>
      </div>
    </fieldset>

    <div class="flex justify-end border-t border-gray-200 pt-6">
      <%= f.submit t('admin.payment_settings.edit.save_settings'), class: "rounded-md bg-gray-900 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
