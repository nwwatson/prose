<%# locals: (segment:, labels:) %>

<%= form_with model: [ :admin, segment ], class: "space-y-6", data: { controller: "segment-builder", segment_builder_count_url_value: segment.persisted? ? count_admin_segment_path(segment) : "" } do |f| %>
  <% if segment.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="list-disc pl-5 text-sm text-red-700">
        <% segment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="max-w-2xl space-y-6">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-900" %>
      <div class="mt-2">
        <%= f.text_field :name, class: "block w-full rounded-md bg-white px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-gray-600 sm:text-sm" %>
      </div>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-gray-900" %>
      <div class="mt-2">
        <%= f.text_area :description, rows: 2, class: "block w-full rounded-md bg-white px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-gray-600 sm:text-sm" %>
      </div>
    </div>

    <hr class="border-gray-200">

    <h3 class="text-sm font-semibold text-gray-900"><%= t('admin.segments.form.filter_criteria') %></h3>

    <% criteria = segment.filter_criteria&.deep_symbolize_keys || {} %>

    <%# Labels filter %>
    <% if labels.any? %>
      <div>
        <p class="text-sm font-medium text-gray-900 mb-2"><%= t('admin.segments.form.labels') %></p>
        <div class="mb-2">
          <select name="segment[label_mode]" class="rounded-md bg-white px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-gray-600 sm:text-sm"
                  data-action="change->segment-builder#refresh">
            <option value="any_of" <%= "selected" if criteria.dig(:labels, :mode) == "any_of" || criteria.dig(:labels, :mode).blank? %>><%= t('admin.segments.form.any_of') %></option>
            <option value="all_of" <%= "selected" if criteria.dig(:labels, :mode) == "all_of" %>><%= t('admin.segments.form.all_of') %></option>
            <option value="none_of" <%= "selected" if criteria.dig(:labels, :mode) == "none_of" %>><%= t('admin.segments.form.none_of') %></option>
          </select>
        </div>
        <div class="space-y-2">
          <% selected_label_ids = criteria.dig(:labels, :ids) || [] %>
          <% labels.each do |label| %>
            <label class="flex items-center gap-2">
              <input type="checkbox" name="segment[label_ids][]" value="<%= label.id %>"
                     <%= "checked" if selected_label_ids.include?(label.id) %>
                     data-action="change->segment-builder#refresh"
                     class="rounded border-gray-300 text-gray-900 focus:ring-gray-600">
              <span class="inline-block h-3 w-3 rounded-full" style="background-color: <%= label.color %>"></span>
              <span class="text-sm text-gray-700"><%= label.name %></span>
            </label>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Date filters %>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <label class="block text-sm font-medium text-gray-900"><%= t('admin.segments.form.subscribed_after') %></label>
        <div class="mt-2">
          <input type="date" name="segment[subscribed_after]" value="<%= criteria[:subscribed_after] %>"
                 data-action="change->segment-builder#refresh"
                 class="block w-full rounded-md bg-white px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-gray-600 sm:text-sm">
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-900"><%= t('admin.segments.form.subscribed_before') %></label>
        <div class="mt-2">
          <input type="date" name="segment[subscribed_before]" value="<%= criteria[:subscribed_before] %>"
                 data-action="change->segment-builder#refresh"
                 class="block w-full rounded-md bg-white px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-gray-600 sm:text-sm">
        </div>
      </div>
    </div>

    <%# Engagement filter %>
    <div>
      <label class="block text-sm font-medium text-gray-900"><%= t('admin.segments.form.engagement') %></label>
      <div class="mt-2">
        <select name="segment[engagement]" data-action="change->segment-builder#refresh"
                class="block w-full rounded-md bg-white px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-gray-600 sm:text-sm">
          <option value=""><%= t('admin.segments.form.any_engagement') %></option>
          <option value="active" <%= "selected" if criteria[:engagement] == "active" %>><%= t('admin.segments.form.active') %></option>
          <option value="inactive" <%= "selected" if criteria[:engagement] == "inactive" %>><%= t('admin.segments.form.inactive') %></option>
        </select>
      </div>
      <p class="mt-1 text-xs text-gray-500"><%= t('admin.segments.form.engagement_help') %></p>
    </div>

    <%# Live subscriber count %>
    <% if segment.persisted? %>
      <div class="rounded-md bg-gray-50 p-4">
        <turbo-frame id="segment_count">
          <%= render "count", count: segment.subscriber_count %>
        </turbo-frame>
      </div>
    <% end %>

    <div class="flex justify-end space-x-3">
      <%= link_to t('shared.cancel'), admin_segments_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
      <%= f.submit class: "rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-700 cursor-pointer" %>
    </div>
  </div>
<% end %>
