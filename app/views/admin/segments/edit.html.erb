<% content_for(:title, "#{t('admin.segments.edit.title')} — #{site_name}") %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('admin.segments.edit.title') %></h1>
    <%= button_to t('shared.delete'), admin_segment_path(@segment), method: :delete, data: { turbo_confirm: t('shared.are_you_sure') }, class: "rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500" %>
  </div>
  <%= render "form", segment: @segment, labels: @labels %>
</div>
