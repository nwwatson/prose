<% content_for(:title, "#{t('admin.segments.index.title')} — #{site_name}") %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('admin.segments.index.title') %></h1>
    <%= link_to t('admin.segments.index.new_segment'), new_admin_segment_path, class: "rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-700" %>
  </div>

  <% if @segments.any? %>
    <div class="overflow-hidden bg-white shadow ring-1 ring-gray-200 sm:rounded-lg">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.segments.index.name') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.segments.index.description') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.segments.index.subscribers') %></th>
            <th class="relative px-6 py-3"><span class="sr-only"><%= t('shared.actions') %></span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @segments.each do |segment| %>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900">
                <%= link_to segment.name, admin_segment_path(segment), class: "hover:text-gray-600" %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= truncate(segment.description, length: 60) %></td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= segment.subscriber_count %></td>
              <td class="whitespace-nowrap px-6 py-4 text-right text-sm font-medium">
                <%= link_to t('shared.edit'), edit_admin_segment_path(segment), class: "text-gray-600 hover:text-gray-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-lg border-2 border-dashed border-gray-300 p-12 text-center">
      <h3 class="text-sm font-semibold text-gray-900"><%= t('admin.segments.index.no_segments') %></h3>
      <p class="mt-1 text-sm text-gray-500"><%= t('admin.segments.index.get_started') %></p>
      <div class="mt-6">
        <%= link_to t('admin.segments.index.new_segment'), new_admin_segment_path, class: "rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-700" %>
      </div>
    </div>
  <% end %>
</div>
