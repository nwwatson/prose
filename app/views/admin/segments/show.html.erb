<% content_for(:title, "#{@segment.name} — #{site_name}") %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @segment.name %></h1>
      <% if @segment.description.present? %>
        <p class="mt-1 text-sm text-gray-500"><%= @segment.description %></p>
      <% end %>
    </div>
    <%= link_to t('shared.edit'), edit_admin_segment_path(@segment), class: "rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-700" %>
  </div>

  <div class="rounded-md bg-gray-50 p-4">
    <p class="text-sm font-medium text-gray-900"><%= t('admin.segments.show.matching_subscribers') %></p>
    <p class="mt-1 text-2xl font-bold text-gray-900"><%= @subscribers.count %></p>
  </div>

  <% if @subscribers.any? %>
    <div class="overflow-hidden bg-white shadow ring-1 ring-gray-200 sm:rounded-lg">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.subscribers.index.email') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.segments.show.labels') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.subscribers.index.subscribed') %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @subscribers.each do |subscriber| %>
            <tr>
              <td class="px-6 py-4 text-sm text-gray-900">
                <%= link_to subscriber.email, admin_subscriber_path(subscriber), class: "hover:text-gray-600" %>
              </td>
              <td class="px-6 py-4">
                <div class="flex flex-wrap gap-1">
                  <% subscriber.subscriber_labels.each do |label| %>
                    <span class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-xs font-medium text-white" style="background-color: <%= label.color %>">
                      <%= label.name %>
                    </span>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= subscriber.confirmed_at&.strftime("%b %-d, %Y") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-lg border-2 border-dashed border-gray-300 p-12 text-center">
      <p class="text-sm text-gray-500"><%= t('admin.segments.show.no_subscribers') %></p>
    </div>
  <% end %>
</div>
