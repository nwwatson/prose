<%= form_with model: [ :admin, label ], class: "space-y-6" do |f| %>
  <% if label.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="list-disc pl-5 text-sm text-red-700">
        <% label.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="max-w-lg space-y-6">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-900" %>
      <div class="mt-2">
        <%= f.text_field :name, class: "block w-full rounded-md bg-white px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-gray-600 sm:text-sm" %>
      </div>
    </div>

    <div>
      <%= f.label :color, class: "block text-sm font-medium text-gray-900" %>
      <div class="mt-2 flex items-center gap-2">
        <%= f.color_field :color, class: "h-8 w-8 cursor-pointer rounded border border-gray-300 p-0.5" %>
        <%= f.text_field :color, class: "block w-full rounded-md bg-white px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-gray-600 sm:text-sm", placeholder: "#6B7280" %>
      </div>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to t('shared.cancel'), admin_subscriber_labels_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
      <%= f.submit class: "rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-700 cursor-pointer" %>
    </div>
  </div>
<% end %>
