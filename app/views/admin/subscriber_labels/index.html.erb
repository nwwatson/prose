<% content_for(:title, "#{t('admin.subscriber_labels.index.title')} — #{site_name}") %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('admin.subscriber_labels.index.title') %></h1>
    <%= link_to t('admin.subscriber_labels.index.new_label'), new_admin_subscriber_label_path, class: "rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-700" %>
  </div>

  <% if @labels.any? %>
    <div class="overflow-hidden bg-white shadow ring-1 ring-gray-200 sm:rounded-lg">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.subscriber_labels.index.name') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.subscriber_labels.index.color') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.subscriber_labels.index.subscribers') %></th>
            <th class="relative px-6 py-3"><span class="sr-only"><%= t('shared.actions') %></span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @labels.each do |label| %>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900">
                <span class="inline-flex items-center gap-2">
                  <span class="inline-block h-3 w-3 rounded-full" style="background-color: <%= label.color %>"></span>
                  <%= label.name %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= label.color %></td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= label.subscribers.count %></td>
              <td class="whitespace-nowrap px-6 py-4 text-right text-sm font-medium">
                <%= link_to t('shared.edit'), edit_admin_subscriber_label_path(label), class: "text-gray-600 hover:text-gray-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-lg border-2 border-dashed border-gray-300 p-12 text-center">
      <h3 class="text-sm font-semibold text-gray-900"><%= t('admin.subscriber_labels.index.no_labels') %></h3>
      <p class="mt-1 text-sm text-gray-500"><%= t('admin.subscriber_labels.index.get_started') %></p>
      <div class="mt-6">
        <%= link_to t('admin.subscriber_labels.index.new_label'), new_admin_subscriber_label_path, class: "rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-700" %>
      </div>
    </div>
  <% end %>
</div>
