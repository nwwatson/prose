<% content_for(:title, "#{t('admin.traffic.show.title')} — #{site_name}") %>

<div>
  <h1 class="text-2xl font-bold text-gray-900"><%= t('admin.traffic.show.title') %></h1>
  <p class="mt-2 text-sm text-gray-600"><%= t('admin.traffic.show.subtitle') %></p>
</div>

<%# KPI Cards %>
<div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-3">
  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="text-sm font-medium text-gray-500 truncate"><%= t('admin.traffic.show.total_views') %></div>
      <div class="mt-1 text-3xl font-semibold text-gray-900"><%= @total_views %></div>
    </div>
  </div>

  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="text-sm font-medium text-gray-500 truncate"><%= t('admin.traffic.show.unique_viewers') %></div>
      <div class="mt-1 text-3xl font-semibold text-gray-900"><%= @unique_viewers %></div>
    </div>
  </div>

  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="text-sm font-medium text-gray-500 truncate"><%= t('admin.traffic.show.top_source') %></div>
      <div class="mt-1 text-3xl font-semibold text-gray-900 capitalize"><%= @top_source %></div>
    </div>
  </div>
</div>

<%# Range Selector + Views Chart %>
<div class="mt-8 bg-white shadow rounded-lg p-6"
     data-controller="traffic-chart"
     data-traffic-chart-data-value="<%= @views_by_day.to_json %>">

  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <h2 class="text-lg font-medium text-gray-900"><%= t('admin.traffic.show.views_over_time') %></h2>

    <div class="inline-flex rounded-md shadow-sm">
      <% %w[7d 30d 90d all].each_with_index do |range, i| %>
        <%
          active = @range == range
          rounded = case i
                    when 0 then "rounded-l-md"
                    when 3 then "-ml-px rounded-r-md"
                    else "-ml-px"
                    end
          classes = if active
                      "#{rounded} bg-blue-600 px-3 py-1.5 text-xs font-medium text-white"
                    else
                      "#{rounded} bg-white px-3 py-1.5 text-xs font-medium text-gray-700 ring-1 ring-inset ring-gray-300 hover:bg-gray-50"
                    end
        %>
        <%= link_to range.upcase, admin_traffic_path(range: range),
              class: classes,
              data: { turbo_action: "replace" } %>
      <% end %>
    </div>
  </div>

  <div data-traffic-chart-target="canvas" class="w-full" style="height: 300px;"></div>

  <% if @views_by_day.empty? %>
    <p class="mt-4 text-sm text-gray-500 text-center"><%= t('admin.traffic.show.no_data') %></p>
  <% end %>
</div>

<%# Traffic Sources %>
<div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-2">
  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4"><%= t('admin.traffic.show.traffic_sources') %></h2>
    <% if @traffic_sources.any? %>
      <div class="space-y-3">
        <% max_count = @traffic_sources.values.max %>
        <% @traffic_sources.each do |source, count| %>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium text-gray-700 capitalize"><%= source %></span>
              <span class="text-gray-500"><%= count %></span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: <%= max_count > 0 ? (count.to_f / max_count * 100).round(1) : 0 %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500"><%= t('admin.traffic.show.no_traffic_data') %></p>
    <% end %>
  </div>

  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4"><%= t('admin.traffic.show.top_referrer_domains') %></h2>
    <% if @top_domains.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr>
            <th class="text-left text-xs font-medium text-gray-500 uppercase pb-2"><%= t('admin.traffic.show.domain') %></th>
            <th class="text-right text-xs font-medium text-gray-500 uppercase pb-2"><%= t('admin.traffic.show.views') %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @top_domains.each do |domain, count| %>
            <tr>
              <td class="py-2 text-sm text-gray-900"><%= domain %></td>
              <td class="py-2 text-sm text-gray-500 text-right"><%= count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-sm text-gray-500"><%= t('admin.traffic.show.no_referrer_data') %></p>
    <% end %>
  </div>
</div>

