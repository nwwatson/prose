              <td class="py-2 text-sm text-gray-500 text-right"><%= count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-sm text-gray-500"><%= t('admin.traffic.show.no_utm_data') %></p>
    <% end %>
  </div>
</div>
