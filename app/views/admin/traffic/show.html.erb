  </div>

  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4"><%= t('admin.traffic.show.utm_mediums') %></h2>
    <% if @utm_mediums.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr>
            <th class="text-left text-xs font-medium text-gray-500 uppercase pb-2"><%= t('admin.traffic.show.medium') %></th>
            <th class="text-right text-xs font-medium text-gray-500 uppercase pb-2"><%= t('admin.traffic.show.views') %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @utm_mediums.each do |medium, count| %>
            <tr>
