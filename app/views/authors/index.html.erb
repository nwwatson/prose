<% content_for(:title, page_title(t('authors.index.title'))) %>

<% content_for(:head) do %>
  <% description = t('authors.index.meet_the_authors', site_name: site_name) %>
  <%= meta_description_tag(description) %>
  <%= open_graph_tags(title: "Authors — #{site_name}", description: description, url: authors_url) %>
  <%= twitter_card_tags(title: "Authors — #{site_name}", description: description) %>
  <%= canonical_tag(authors_url) %>
<% end %>

<div>
  <h1 class="page-heading"><%= t('authors.index.title') %></h1>
  <p class="mt-2 muted-text"><%= t('authors.index.meet_the_people', site_name: site_name) %></p>
</div>

<div class="mt-8 space-y-8">
  <% @authors.each do |identity| %>
    <div class="author-card">
      <div class="author-card__inner">
        <% if identity.avatar.attached? %>
          <%= image_tag identity.avatar.variant(resize_to_fill: [96, 96]),
                class: "author-card__avatar",
                alt: identity.name %>
        <% else %>
          <div class="author-card__avatar-placeholder">
            <span class="author-card__avatar-initial"><%= identity.name.first.upcase %></span>
          </div>
        <% end %>

        <div class="author-card__info">
          <h2 class="font-display text-xl font-bold">
            <%= link_to identity.name, author_path(identity, handle: identity.handle),
                  class: "author-card__name" %>
          </h2>

          <% if identity.bio.present? %>
            <p class="author-card__bio"><%= strip_tags(identity.bio_html).truncate(200) %></p>
          <% end %>

          <div class="author-card__meta">
            <span><%= pluralize(identity.user.posts.live.count, "post") %></span>
            <% if identity.has_social_links? %>
              <span>&middot;</span>
              <div class="author-card__social-links">
                <% if identity.website_url.present? %>
                  <%= link_to t('authors.index.website'), identity.website_url, class: "author-card__social-link", target: "_blank", rel: "noopener" %>
                <% end %>
                <% if identity.twitter_url.present? %>
                  <%= link_to "X", identity.twitter_url, class: "author-card__social-link", target: "_blank", rel: "noopener" %>
                <% end %>
                <% if identity.github_url.present? %>
                  <%= link_to "GitHub", identity.github_url, class: "author-card__social-link", target: "_blank", rel: "noopener" %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
