<%# locals: (show_close: false) %>
<div class="flex h-full flex-col">
  <%# Logo %>
  <div class="flex h-16 items-center justify-between border-b border-gray-200 px-6">
    <span class="text-xl font-bold text-gray-900"><%= site_name %></span>
    <% if show_close %>
      <button type="button" data-action="click->admin-sidebar#close"
              class="rounded-md p-1 text-gray-400 hover:text-gray-600 focus:outline-none">
        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    <% end %>
  </div>

  <%# Navigation %>
  <nav class="flex-1 space-y-1 px-3 py-4">
    <div class="space-y-1">
      <%= admin_nav_link t('shared.home'), admin_root_path, icon: "home" %>
    </div>

    <div class="pt-4">
      <p class="px-3 text-xs font-semibold uppercase tracking-wider text-gray-400"><%= t('layouts.admin.content') %></p>
      <div class="mt-2 space-y-1">
        <%= admin_nav_link t('layouts.admin.all_posts'), admin_posts_path, icon: "document" %>
        <div class="ml-5 space-y-0.5">
          <%= admin_nav_link t('shared.published'), admin_posts_path(status: "published"), icon: "check-circle", small: true %>
          <%= admin_nav_link t('shared.scheduled'), admin_posts_path(status: "scheduled"), icon: "clock", small: true %>
          <%= admin_nav_link t('shared.drafts'), admin_posts_path(status: "draft"), icon: "pencil", small: true %>
        </div>
        <%= admin_nav_link t('layouts.admin.pages'), admin_pages_path, icon: "document-text" %>
      </div>
    </div>

    <div class="pt-4">
      <p class="px-3 text-xs font-semibold uppercase tracking-wider text-gray-400"><%= t('layouts.admin.audience') %></p>
      <div class="mt-2 space-y-1">
        <%= admin_nav_link t('layouts.admin.subscribers'), admin_subscribers_path, icon: "users" %>
        <%= admin_nav_link t('layouts.admin.labels'), admin_subscriber_labels_path, icon: "tag" %>
        <%= admin_nav_link t('layouts.admin.segments'), admin_segments_path, icon: "funnel" %>
        <%= admin_nav_link t('layouts.admin.newsletters'), admin_newsletters_path, icon: "envelope" %>
        <%= admin_nav_link t('layouts.admin.newsletter_settings'), edit_admin_newsletter_settings_path, icon: "adjustments" %>
        <%= admin_nav_link t('layouts.admin.growth'), admin_growth_path, icon: "trending-up" %>
        <%= admin_nav_link t('layouts.admin.traffic'), admin_traffic_path, icon: "chart-bar" %>
      </div>
    </div>

    <% if PaymentService.configured? %>
      <div class="pt-4">
        <p class="px-3 text-xs font-semibold uppercase tracking-wider text-gray-400"><%= t('layouts.admin.memberships') %></p>
        <div class="mt-2 space-y-1">
          <%= admin_nav_link t('layouts.admin.membership_tiers'), admin_membership_tiers_path, icon: "collection" %>
          <%= admin_nav_link t('layouts.admin.members'), admin_memberships_path, icon: "user-group" %>
          <%= admin_nav_link t('layouts.admin.revenue'), admin_revenue_path, icon: "currency-dollar" %>
        </div>
      </div>
    <% end %>

    <div class="pt-4">
      <p class="px-3 text-xs font-semibold uppercase tracking-wider text-gray-400"><%= t('layouts.admin.system') %></p>
      <div class="mt-2 space-y-1">
        <%= admin_nav_link t('layouts.admin.profile'), edit_admin_profile_path, icon: "user-circle" %>
        <%= admin_nav_link t('layouts.admin.settings'), edit_admin_settings_path, icon: "cog" %>
        <%= admin_nav_link t('layouts.admin.passkeys'), admin_passkeys_path, icon: "finger-print" %>
        <%= admin_nav_link t('layouts.admin.api_tokens'), admin_api_tokens_path, icon: "key" %>
      </div>
    </div>
  </nav>

  <%# User menu %>
  <div class="border-t border-gray-200 p-4">
    <div class="flex items-center">
      <div class="flex-1 truncate">
        <p class="text-sm font-medium text-gray-900"><%= current_user.display_name %></p>
        <p class="truncate text-xs text-gray-500"><%= current_user.email %></p>
      </div>
      <%= button_to t('shared.sign_out'), admin_session_path, method: :delete,
            class: "ml-2 rounded-md px-2 py-1.5 text-xs text-gray-500 hover:bg-gray-100 hover:text-gray-700" %>
    </div>
  </div>
</div>
