<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "Admin — #{site_name}" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex,nofollow">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "lexxy" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <div class="flex h-full" data-controller="admin-sidebar">
      <%# Desktop sidebar (static) %>
      <aside class="hidden w-64 flex-shrink-0 border-r border-gray-200 bg-white lg:block">
        <%= render "layouts/admin_sidebar_content" %>
      </aside>

      <%# Mobile sidebar (slide-over) %>
      <div data-admin-sidebar-target="backdrop"
           data-action="click->admin-sidebar#close"
           class="fixed inset-0 z-40 bg-black/30 transition-opacity duration-300 hidden opacity-0 lg:hidden"></div>
      <aside data-admin-sidebar-target="sidebar"
             class="fixed inset-y-0 left-0 z-50 w-64 -translate-x-full border-r border-gray-200 bg-white transition-transform duration-300 ease-in-out lg:hidden">
        <%= render "layouts/admin_sidebar_content", show_close: true %>
      </aside>

      <%# Main content %>
      <div class="flex flex-1 flex-col overflow-hidden">
        <%# Mobile header %>
        <header class="flex h-16 items-center border-b border-gray-200 bg-white px-4 lg:hidden">
          <button type="button" data-action="click->admin-sidebar#open" class="mr-3 rounded-md p-2 text-gray-500 hover:bg-gray-100 hover:text-gray-900 focus:outline-none">
            <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
          <span class="text-xl font-bold text-gray-900"><%= site_name %></span>
        </header>

        <%# Flash messages %>
        <% if notice %>
          <div class="bg-green-50 border-b border-green-200 px-4 py-3">
            <p class="text-sm text-green-800"><%= notice %></p>
          </div>
        <% end %>
        <% if alert %>
          <div class="bg-red-50 border-b border-red-200 px-4 py-3">
            <p class="text-sm text-red-800"><%= alert %></p>
          </div>
        <% end %>

        <%# Page content %>
        <main class="flex-1 overflow-y-auto p-4 sm:p-6">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
