<!DOCTYPE html>
<html>
  <head>
    <script>
      (function() {
        var mode = '<%= theme_mode %>';
        if (mode === 'dark') {
          document.documentElement.classList.add('dark');
        } else if (mode === 'visitor_choice') {
          var p = localStorage.getItem('theme');
          if (p === 'dark' || (!p && matchMedia('(prefers-color-scheme:dark)').matches))
            document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <title><%= content_for(:title) || site_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= site_name %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= json_ld_tag({ "@context": "https://schema.org", "@type": "Organization", name: site_name, url: root_url }) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="alternate" type="application/rss+xml" title="<%= site_name %> RSS Feed" href="<%= feed_path(format: :xml) %>">

    <%= font_stylesheet_tags %>
    <%= background_style_tag %>
    <%= dark_theme_style_tag %>
    <%= typography_style_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-cream text-charcoal font-serif min-h-screen flex flex-col">
    <%# Masthead %>
    <header class="masthead">
      <div class="masthead__inner">
        <div class="masthead__title-row">
          <%= link_to site_name, root_path, class: "masthead__title" %>
          <% if theme_mode == "visitor_choice" %>
            <div class="masthead__theme-toggle" data-controller="theme-toggle">
              <button type="button" data-action="click->theme-toggle#toggle" data-theme-toggle-target="button"
                      class="masthead__toggle-btn"
                      aria-label="<%= t('layouts.application.toggle_dark_mode') %>">
                <span data-theme-toggle-target="icon">
                  <%# Moon icon (shown in light mode) %>
                  <svg class="h-5 w-5 dark:hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
                  </svg>
                  <%# Sun icon (shown in dark mode) %>
                  <svg class="h-5 w-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
                  </svg>
                </span>
              </button>
            </div>
          <% end %>
        </div>
        <nav class="masthead__nav">
          <%= link_to t('shared.home'), root_path, class: "masthead__nav-link" %>
          <% Page.navigation.each do |nav_page| %>
            <%= link_to nav_page.title, page_path(nav_page.slug), class: "masthead__nav-link" %>
          <% end %>
        </nav>
      </div>
    </header>

    <%# Flash messages %>
    <% if notice %>
      <div class="flash flash--notice">
        <div class="flash__inner">
          <p class="flash__text"><%= notice %></p>
        </div>
      </div>
    <% end %>

    <%# Main content %>
    <main class="mx-auto w-full max-w-3xl flex-1 px-4 py-8">
      <%= yield %>
    </main>

    <%# Footer %>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <p><%= t('layouts.application.copyright_html', year: Date.current.year, site_name: site_name) %></p>
      </div>
    </footer>
  </body>
</html>
