<% content_for(:title, page_title(t('memberships.success.title'))) %>

<div class="mx-auto max-w-lg px-4 py-16 text-center">
  <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-green-100">
    <svg class="h-8 w-8 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
    </svg>
  </div>
  <h1 class="mt-6 font-display text-3xl font-bold text-charcoal dark:text-gray-100"><%= t('memberships.success.title') %></h1>
  <p class="mt-4 text-lg text-gray-600 dark:text-gray-400"><%= t('memberships.success.description') %></p>
  <%= link_to t('memberships.success.continue_reading'), root_path, class: "mt-8 inline-block rounded-md bg-gray-900 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-gray-700" %>
</div>
