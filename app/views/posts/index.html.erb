<% content_for(:title, page_title) %>

<% content_for(:head) do %>
  <%= meta_description_tag(site_description) %>
  <%= open_graph_tags(title: site_name, description: site_description, url: root_url) %>
  <%= twitter_card_tags(title: site_name, description: site_description) %>
  <%= canonical_tag(root_url) %>
  <%= json_ld_tag({ "@context": "https://schema.org", "@type": "WebSite", name: site_name, url: root_url, description: site_description }) %>
<% end %>

<%# Featured post hero %>
<% if @featured_posts.any? %>
  <% @featured_posts.each do |post| %>
    <article class="post-card post-card--featured">
      <header>
        <h2 class="post-card__title">
          <%= link_to post.title, post_path(post, slug: post.slug), class: "post-card__link" %>
        </h2>
        <% if post.subtitle.present? %>
          <p class="post-card__subtitle"><%= post.subtitle %></p>
        <% end %>
        <div class="post-card__meta post-meta">
          <span><%= t('shared.by') %> <%= author_link(post.user) %></span>
          <span class="post-meta__separator">&middot;</span>
          <time datetime="<%= post.published_at.iso8601 %>"><%= post.published_at.strftime("%B %-d, %Y") %></time>
          <span class="post-meta__separator">&middot;</span>
          <span><%= post.reading_time_minutes %> <%= t('shared.min_read') %></span>
        </div>
      </header>
      <% if post.content.present? %>
        <div class="post-card__excerpt">
          <%= truncate(post.content.to_plain_text, length: 300) %>
        </div>
      <% end %>
    </article>
  <% end %>
<% end %>

<%# Search %>
<div class="mb-8 section-divider pb-8">
  <%= form_with url: posts_path, method: :get, data: { turbo_action: "advance" }, class: "search-bar" do |f| %>
    <%= f.search_field :q, value: @query, placeholder: t('posts.index.search_placeholder'), class: "form-input search-bar__input" %>
    <%= f.submit t('shared.search'), class: "btn btn--primary" %>
  <% end %>
</div>

<%# Post listing with infinite scroll %>
<% if @posts.any? %>
  <div class="space-y-8" data-controller="infinite-scroll">
    <%= render "posts/post_page", posts: @posts, page: @page, next_page: @next_page, query: @query %>
  </div>
<% elsif @query.present? %>
  <div class="empty-state">
    <p class="empty-state__text"><%= t('posts.index.no_posts_found', query: @query) %></p>
  </div>
<% elsif @featured_posts.empty? %>
  <div class="empty-state">
    <p class="empty-state__text"><%= t('posts.index.no_posts_yet') %></p>
  </div>
<% end %>

<%# Subscribe section %>
<div class="subscribe-cta">
  <h3 class="subscribe-cta__heading"><%= t('posts.index.subscribe_to', site_name: site_name) %></h3>
  <p class="subscribe-cta__description"><%= t('posts.index.get_notified') %></p>
  <div class="subscribe-cta__form-wrapper">
    <%= render "subscriptions/form" %>
  </div>
</div>
