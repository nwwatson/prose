<div class="max-w-6xl mx-auto py-6">
  <!-- Breadcrumb and Actions -->
  <div class="flex justify-between items-start mb-6">
    <div>
      <div class="flex items-center space-x-2 text-sm text-gray-500 mb-2">
        <%= link_to @publication.name, @publication, class: "hover:text-gray-700" %>
        <span>/</span>
        <span><%= @post.title %></span>
      </div>
      <div class="flex items-center space-x-4">
        <h1 class="text-3xl font-bold text-gray-900"><%= @post.title %></h1>
        <span class="px-3 py-1 rounded-full text-sm font-medium <%= 
          case @post.status
          when 'published' then 'bg-green-100 text-green-800'
          when 'scheduled' then 'bg-blue-100 text-blue-800'
          when 'draft' then 'bg-yellow-100 text-yellow-800'
          when 'archived' then 'bg-gray-100 text-gray-800'
          end %>">
          <%= @post.status.humanize %>
        </span>
      </div>
      <div class="flex items-center space-x-4 mt-2 text-sm text-gray-500">
        <% if @post.published_at %>
          <span>Published <%= time_ago_in_words(@post.published_at) %> ago</span>
        <% elsif @post.scheduled_at %>
          <span>Scheduled for <%= @post.scheduled_at.strftime("%B %d, %Y at %I:%M %p") %></span>
        <% else %>
          <span>Created <%= time_ago_in_words(@post.created_at) %> ago</span>
        <% end %>
        <span>•</span>
        <span><%= @post.reading_time %> min read</span>
        <span>•</span>
        <span><%= pluralize(@post.view_count, 'view') %></span>
      </div>
    </div>
    
    <div class="flex space-x-2">
      <%= link_to "Edit", edit_publication_post_path(@publication, @post), 
          class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors" %>
      <%= link_to "Preview", preview_publication_post_path(@publication, @post),
          target: "_blank", rel: "noopener",
          class: "bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-2 px-4 rounded-lg transition-colors" %>
      
      <!-- Status Actions -->
      <% if @post.draft? || @post.scheduled? %>
        <%= button_to "Publish Now", publish_publication_post_path(@publication, @post), 
            method: :patch,
            class: "bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors" %>
      <% elsif @post.published? %>
        <%= button_to "Unpublish", unpublish_publication_post_path(@publication, @post), 
            method: :patch,
            data: { confirm: "Are you sure you want to unpublish this post?" },
            class: "bg-yellow-600 hover:bg-yellow-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors" %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
    <!-- Main Content -->
    <div class="lg:col-span-3">
      <!-- Featured Image -->
      <% if @post.featured_image.attached? %>
        <div class="mb-8">
          <%= image_tag @post.featured_image, 
              class: "w-full h-64 object-cover rounded-lg shadow-lg",
              alt: @post.title %>
        </div>
      <% end %>

      <!-- Summary -->
      <% if @post.summary.present? %>
        <div class="bg-blue-50 border-l-4 border-blue-400 p-6 mb-8">
          <h2 class="text-lg font-semibold text-blue-900 mb-2">Summary</h2>
          <p class="text-blue-800 leading-relaxed"><%= simple_format(@post.summary) %></p>
        </div>
      <% end %>

      <!-- Post Content -->
      <div class="bg-white shadow-sm border border-gray-200 rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900">Content</h2>
        </div>
        <div class="p-6">
          <div class="prose prose-lg max-w-none">
            <%= @post.content %>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="mt-8 flex justify-between items-center">
        <div class="flex space-x-4">
          <%= link_to 'Edit Post', edit_publication_post_path(@publication, @post), 
              class: "text-blue-600 hover:text-blue-800 font-medium" %>
          <%= link_to 'Back to Publication', @publication, 
              class: "text-gray-600 hover:text-gray-800 font-medium" %>
        </div>
        
        <div class="flex space-x-2">
          <% if @post.featured? %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
              ⭐ Featured
            </span>
          <% end %>
          <% if @post.pinned? %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
              📌 Pinned
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="lg:col-span-1 space-y-6">
      <!-- Post Details -->
      <div class="bg-white shadow-sm border border-gray-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Post Details</h3>
        <div class="space-y-3 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-600">Status:</span>
            <span class="font-medium capitalize"><%= @post.status %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Views:</span>
            <span class="font-medium"><%= @post.view_count %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Reading time:</span>
            <span class="font-medium"><%= @post.reading_time %> min</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Word count:</span>
            <span class="font-medium"><%= @post.word_count %></span>
          </div>
          <% if @post.published_at %>
            <div class="flex justify-between">
              <span class="text-gray-600">Published:</span>
              <span class="font-medium"><%= @post.published_at.strftime("%b %d, %Y") %></span>
            </div>
          <% end %>
          <% if @post.scheduled_at %>
            <div class="flex justify-between">
              <span class="text-gray-600">Scheduled:</span>
              <span class="font-medium"><%= @post.scheduled_at.strftime("%b %d, %Y") %></span>
            </div>
          <% end %>
          <div class="flex justify-between">
            <span class="text-gray-600">Created:</span>
            <span class="font-medium"><%= @post.created_at.strftime("%b %d, %Y") %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Updated:</span>
            <span class="font-medium"><%= @post.updated_at.strftime("%b %d, %Y") %></span>
          </div>
        </div>
      </div>

      <!-- SEO Preview -->
      <% if @post.meta_title.present? || @post.meta_description.present? %>
        <div class="bg-white shadow-sm border border-gray-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">SEO Preview</h3>
          <div class="border border-gray-200 rounded-md p-4">
            <h4 class="text-blue-600 text-lg font-medium hover:underline">
              <%= @post.seo_title %>
            </h4>
            <p class="text-green-700 text-sm mt-1">
              <%= @publication.primary_domain %>/posts/<%= @post.slug %>
            </p>
            <p class="text-gray-600 text-sm mt-2 line-clamp-3">
              <%= @post.seo_description %>
            </p>
          </div>
        </div>
      <% end %>

      <!-- Danger Zone -->
      <div class="bg-white shadow-sm border border-red-200 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-red-900 mb-4">Danger Zone</h3>
        <div class="space-y-3">
          <% if @post.published? %>
            <%= button_to "Unpublish Post", unpublish_publication_post_path(@publication, @post), 
                method: :patch,
                data: { confirm: "This will unpublish the post and remove it from public view. Are you sure?" },
                class: "w-full bg-yellow-600 hover:bg-yellow-700 text-white font-medium py-2 px-4 rounded-md transition-colors" %>
          <% end %>
          
          <%= button_to "Delete Post", [@publication, @post], 
              method: :delete,
              data: { confirm: "This action cannot be undone. Are you sure you want to delete this post?" },
              class: "w-full bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded-md transition-colors" %>
        </div>
      </div>
    </div>
  </div>
</div>