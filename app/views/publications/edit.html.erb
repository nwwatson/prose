<div class="max-w-4xl mx-auto py-6">
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Edit Publication</h1>
    <p class="text-gray-600 mt-2">Update your publication settings</p>
  </div>

  <%= render 'form', publication: @publication %>

  <div class="mt-6 flex space-x-4">
    <%= link_to 'View Publication', @publication, 
        class: "text-blue-600 hover:text-blue-800 font-medium" %>
    <%= link_to 'Back to Publications', publications_path, 
        class: "text-gray-600 hover:text-gray-800 font-medium" %>
  </div>
</div>